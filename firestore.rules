rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{taskId} {
      allow read, write: if request.auth != null && (request.resource == null || request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }
    match /habits/{habitId} {
      allow read, write: if request.auth != null && (request.resource == null || request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }
    match /tab_activities/{activityId} {
      allow read, write: if request.auth != null && (request.resource == null || request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }
  }
}
